# Example environment configuration for the Central License Server
# Copy this file to `.env` and customise values as appropriate.

# SQLAlchemy database URI. Use your Supabase PostgreSQL connection here.
DATABASE_URL=postgresql+psycopg2://username:password@host:5432/database_name

# Secret key used by Flask to sign sessions and other cryptographic
# components. Generate a long random string for production.
SECRET_KEY=change-this-secret-key

# Super admin credentials. These will be used to create the first
# administrator account when the application starts.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Optional API secret key. When provided clients can include this
# value in their requests to authenticate. You can leave this blank
# if you do not need additional API authentication.
API_SECRET_KEY=api-secret-key